{
  "title": "P1 用户手册",
  "styles":{
    "website": "/sidebar.css",
    "pdf": "/pdf.css"
  },

  "plugins": [
    "chapter-fold",
    "expandable-chapters",
    "back-to-top-button",
    "password-z",
    "-lunr",
    "-search",
    "search-pro",
    "theme-fexa",
    "splitter",
    "-sharing",
    "klipse"
  ],
  "variables": {
    "themeFexa": {
      "showHome": false,
      "showNavigator": false
    }
  },
  "pluginsConfig": {
    "theme-fexa": {
      "search-placeholder": "输入关键字搜索",
      "logo": "/photo/logo.png",
      "logoLink": "https://www.elephantrobotics.com",
      "favicon": "./favicon.ico"
    },
    "password": {}
  },
  "pdf": {
    "pageNumbers": true,
    "fontSize": 12,
    "paperSize": "a4",
    "tocTitle": "P1 用户手册",
    "extraCss": "pdf.css",
    "margin": {
      "right": 20,
      "left": 20,
      "top": 20,
      "bottom": 20
    },
    "chapterMark": "pagebreak",
    "pageBreaksBefore": "/"
  }
}